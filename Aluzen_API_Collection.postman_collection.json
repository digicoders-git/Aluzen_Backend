{
  "info": {
    "name": "Aluzen API Collection",
    "description": "Complete API collection for Aluzen Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:3200",
      "type": "string"
    },
    {
      "key": "TOKEN",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Admin",
      "item": [
        {
          "name": "Create Admin",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Admin User", "type": "text" },
                { "key": "email", "value": "admin@aluzen.in", "type": "text" },
                { "key": "password", "value": "admin123", "type": "text" },
                { "key": "profilePhoto", "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{BASE_URL}}/admin/create", "host": ["{{BASE_URL}}"], "path": ["admin", "create"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) pm.collectionVariables.set('TOKEN', res.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@aluzen.in\",\n  \"password\": \"admin123\"\n}"
            },
            "url": { "raw": "{{BASE_URL}}/admin/login", "host": ["{{BASE_URL}}"], "path": ["admin", "login"] }
          }
        },
        {
          "name": "Get Admin",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{BASE_URL}}/admin/get", "host": ["{{BASE_URL}}"], "path": ["admin", "get"] }
          }
        },
        {
          "name": "Update Admin Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{TOKEN}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Updated Admin", "type": "text" },
                { "key": "email", "value": "admin@aluzen.in", "type": "text" },
                { "key": "currentPassword", "value": "admin123", "type": "text" },
                { "key": "newPassword", "value": "newpass123", "type": "text" },
                { "key": "profilePhoto", "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{BASE_URL}}/admin/update/:id", "host": ["{{BASE_URL}}"], "path": ["admin", "update", ":id"], "variable": [{ "key": "id", "value": "ADMIN_ID_HERE" }] }
          }
        }
      ]
    },
